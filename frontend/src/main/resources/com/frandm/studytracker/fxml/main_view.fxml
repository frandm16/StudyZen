<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.effect.GaussianBlur?>
<?import org.kordamp.ikonli.javafx.FontIcon?>


<?import atlantafx.base.controls.ToggleSwitch?>
<StackPane fx:id="rootPane" prefHeight="700.0" prefWidth="1000.0"
           stylesheets="@/com/frandm/studytracker/css/styles.css"
           styleClass="root-pane"
           xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.frandm.studytracker.controllers.PomodoroController">

    <MediaView fx:id="backgroundVideoView"
               mouseTransparent="true"
               preserveRatio="false"
               smooth="true"
               StackPane.alignment="CENTER" />

    <Region fx:id="backgroundVideoOverlay" maxHeight="Infinity" maxWidth="Infinity" styleClass="background-video">

    </Region>

    <VBox >
        <HBox fx:id="titleBar" alignment="CENTER_RIGHT" minHeight="40.0" prefHeight="40.0" styleClass="custom-title-bar">
            <Region HBox.hgrow="ALWAYS" />

            <Button fx:id="minBtn" styleClass="window-btn" focusTraversable="false">
                <graphic>
                    <FontIcon iconLiteral="fltfmz-minimize-16" iconSize="16" styleClass="window-icon-minimize"/>
                </graphic>
            </Button>

            <Button fx:id="maxBtn" styleClass="window-btn" focusTraversable="false">
                <graphic>
                    <FontIcon iconLiteral="ri-window-maximize" iconSize="16" styleClass="window-icon-maximize"/>
                </graphic>
            </Button>

            <Button fx:id="closeBtn" styleClass="window-btn, close-btn" focusTraversable="false">
                <graphic>
                    <FontIcon iconLiteral="mdi2w-window-close" iconSize="16" styleClass="window-icon-close"/>
                </graphic>
            </Button>
        </HBox>
        <StackPane VBox.vgrow="ALWAYS" maxWidth="Infinity" >
            <GridPane StackPane.alignment="TOP_CENTER"  maxHeight="-Infinity" maxWidth="Infinity">
                <columnConstraints>
                    <ColumnConstraints fx:id="colLeftStats" percentWidth="25" />
                    <ColumnConstraints fx:id="colCenterStats" percentWidth="50" />
                    <ColumnConstraints fx:id="colRightStats" percentWidth="25" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints vgrow="ALWAYS" />
                </rowConstraints>
                <ScrollPane fx:id="statsContainer" visible="false" managed="false" GridPane.columnIndex="1" fitToWidth="true" />
            </GridPane >
            <GridPane  StackPane.alignment="TOP_CENTER" fx:id="mainContainer" maxHeight="Infinity" maxWidth="Infinity" >
                <columnConstraints>
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints  percentWidth="50" />
                    <ColumnConstraints percentWidth="25" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints vgrow="ALWAYS" />
                </rowConstraints>
                <VBox fx:id="scheduleListContainer" GridPane.columnIndex="2" alignment="CENTER"
                      GridPane.valignment="TOP" GridPane.halignment="RIGHT" maxWidth="-Infinity" maxHeight="-Infinity"/>
                <VBox GridPane.columnIndex="1" spacing="20" alignment="CENTER" >
                    <StackPane fx:id="stackpaneCircle"  VBox.vgrow="ALWAYS" >
                        <VBox fx:id="mainVbox" maxWidth="-Infinity" maxHeight="-Infinity" styleClass="main-vbox" alignment="CENTER" >

                            <HBox maxWidth="Infinity" maxHeight="-Infinity">
                                <HBox styleClass="timer-hbox" onMousePressed="#toggleSettings" >
                                    <FontIcon fx:id="timerIcon" iconLiteral="mdi2t-timer-outline" styleClass="timer-icon" />
                                    <VBox styleClass="timer-vbox">
                                        <Label fx:id="ModeNameLabel" text="Pomodoro" styleClass="timer-name" />
                                        <Label fx:id="ModeSubnameLabel" text="Menu" styleClass="timer-description" />
                                    </VBox>
                                </HBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox fx:id="activeTaskContainer" spacing="5" maxWidth="Infinity" maxHeight="-Infinity" alignment="TOP_RIGHT" minHeight="30">
                                </HBox>
                            </HBox>

                            <StackPane >
                                <VBox maxWidth="-Infinity" maxHeight="-Infinity" alignment="CENTER">
                                    <VBox  fx:id="timerTextContainer" maxWidth="-Infinity" maxHeight="-Infinity" alignment="CENTER">
                                        <Label fx:id="timerLabel" text="25:00" styleClass="timer-label"/>
                                    </VBox>
                                    <HBox alignment="CENTER" fx:id="buttonsHbox" >

                                        <Button fx:id="startPauseBtn" onAction="#handleMainAction"
                                                styleClass="menu-button" alignment="CENTER"
                                                contentDisplay="GRAPHIC_ONLY" >
                                        </Button>
                                        <Button fx:id="skipBtn" onAction="#handleSkip"
                                                styleClass="menu-button" alignment="CENTER"
                                                contentDisplay="GRAPHIC_ONLY" >
                                            <graphic>
                                                <FontIcon iconLiteral="mdi2s-skip-next" styleClass="menu-icon" />
                                            </graphic>
                                            <tooltip>
                                                <Tooltip text="Skip" showDelay="250ms" />
                                            </tooltip>
                                        </Button>
                                        <Button fx:id="finishBtn" onAction="#handleFinish"
                                                styleClass="menu-button" alignment="CENTER"
                                                contentDisplay="GRAPHIC_ONLY" >
                                            <graphic>
                                                <FontIcon iconLiteral="mdi2s-stop" styleClass="menu-icon" />
                                            </graphic>
                                            <tooltip>
                                                <Tooltip text="Finish" showDelay="250ms" />
                                            </tooltip>
                                        </Button>
                                    </HBox>
                                </VBox>

                            </StackPane>

                        </VBox>
                    </StackPane>
                </VBox>
            </GridPane>
            <GridPane StackPane.alignment="TOP_CENTER"  maxHeight="-Infinity" maxWidth="Infinity">
                <columnConstraints>
                    <ColumnConstraints percentWidth="15" />
                    <ColumnConstraints percentWidth="70" />
                    <ColumnConstraints percentWidth="15" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints vgrow="ALWAYS" />
                </rowConstraints>
                <VBox fx:id="plannerContainer" visible="false" managed="false" alignment="TOP_CENTER" GridPane.columnIndex="1" >
                    <padding><Insets top="40" bottom="40" left="50" right="50"/></padding>
                </VBox>
            </GridPane>
            <GridPane StackPane.alignment="TOP_CENTER"  maxHeight="-Infinity" maxWidth="Infinity">
                <columnConstraints>
                    <ColumnConstraints percentWidth="15" />
                    <ColumnConstraints percentWidth="70" />
                    <ColumnConstraints percentWidth="15" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints vgrow="ALWAYS" />
                </rowConstraints>
                <VBox fx:id="historyContainer" visible="false" managed="false" alignment="TOP_CENTER" GridPane.columnIndex="1" >
                </VBox>
            </GridPane>
        </StackPane>
    </VBox>

    <HBox fx:id="floatingDock" spacing="15" alignment="CENTER"
          StackPane.alignment="BOTTOM_CENTER"
          maxWidth="-Infinity" maxHeight="-Infinity"
          styleClass="floating-dock">
        <StackPane.margin><Insets bottom="30" /></StackPane.margin>
    </HBox>


    <GridPane fx:id="settingsPane" visible="false" managed="false" maxHeight="Infinity" maxWidth="Infinity">
        <columnConstraints>
            <ColumnConstraints percentWidth="25" />
            <ColumnConstraints percentWidth="50" />
            <ColumnConstraints percentWidth="25" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints percentHeight="8" />
            <RowConstraints percentHeight="84" />
            <RowConstraints percentHeight="8" />
        </rowConstraints>

        <Region onMouseClicked="#toggleSettings" style="-fx-background-color: rgba(0,0,0,0.5);" GridPane.columnSpan="3" GridPane.rowSpan="3">
            <effect><GaussianBlur radius="15" /></effect>
        </Region>

        <VBox fx:id="settingsBox" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="settings-sidebar">

            <HBox alignment="CENTER_LEFT" style="-fx-padding: 18 25 12 25;">
                <Label text="SETTINGS" styleClass="sidebar-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#toggleSettings" text="✕" styleClass="close-button" />
            </HBox>
            <Separator />

            <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" styleClass="settings-tabpane">
                <Tab text="General">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="25" style="-fx-padding: 25;">

                            <VBox spacing="10">
                                <Label text="Mode Selector" styleClass="section-label" />
                                <HBox styleClass="segmented-button" alignment="CENTER" maxWidth="-Infinity">
                                    <ToggleButton fx:id="pomoModeBtn" text="Pomodoro" styleClass="left-pill" />
                                    <ToggleButton fx:id="timerModeBtn" text="Timer" />
                                    <ToggleButton fx:id="countdownModeBtn" text="Countdown" styleClass="right-pill" />
                                </HBox>
                            </VBox>

                            <VBox fx:id="pomoSettingsPane" spacing="25" visible="false" managed="false">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Time (minutes)" styleClass="section-label"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button onAction="#handleResetTimeSettings" text="Reset" styleClass="reset-button"/>
                                </HBox>
                                <VBox spacing="8">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="Pomodoro"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="workValLabel" text="25" styleClass="val-label"/>
                                    </HBox>
                                    <Slider fx:id="workSlider" min="1" max="180"/>
                                </VBox>
                                <VBox spacing="8">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="Short Break"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="shortValLabel" text="5" styleClass="val-label"/>
                                    </HBox>
                                    <Slider fx:id="shortSlider" min="1" max="25"/>
                                </VBox>
                                <VBox spacing="8">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="Long Break"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="longValLabel" text="15" styleClass="val-label"/>
                                    </HBox>
                                    <Slider fx:id="longSlider" min="1" max="50"/>
                                </VBox>
                                <VBox spacing="8">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="Long Break Interval"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="intervalValLabel" text="4" styleClass="val-label"/>
                                    </HBox>
                                    <Slider fx:id="intervalSlider" min="1" max="20"/>
                                </VBox>
                                <VBox spacing="15">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="Auto Start Breaks" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                        <ToggleSwitch fx:id="autoBreakToggle" styleClass="toggle-switch"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="Auto Start Pomodoros" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                        <ToggleSwitch fx:id="autoPomoToggle" styleClass="toggle-switch"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="Count Break Time" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                        <ToggleSwitch fx:id="countBreakTime" styleClass="toggle-switch"/>
                                    </HBox>
                                </VBox>

                            </VBox>
                            <VBox fx:id="countdownSettingsPane" spacing="25" visible="false" managed="false">
                                <VBox spacing="5">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="Countdown Timer" />
                                        <Pane HBox.hgrow="ALWAYS" />
                                        <Label fx:id="countdownValLabel" text="10" styleClass="val-label" />
                                    </HBox>
                                    <Slider fx:id="countdownSlider" min="1" max="180" />
                                </VBox>
                            </VBox>
                        </VBox>
                    </ScrollPane>
                </Tab>
                <Tab text="Appearance">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="16" style="-fx-padding: 22 25 22 25;">

                            <VBox spacing="14" styleClass="settings-card">
                                <Label text="UI Customization" styleClass="settings-card-title"/>
                                <VBox spacing="8">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="Stats Width"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="widthSliderValLabel" text="50%" styleClass="val-label"/>
                                    </HBox>
                                    <Slider fx:id="widthSlider" min="25" value="50"/>
                                </VBox>
                                <VBox spacing="8">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="UI Scale"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="circleSizeValLabel" text="25" styleClass="val-label"/>
                                    </HBox>
                                    <Slider fx:id="circleSizeSlider" min="30" max="75" value="50"/>
                                </VBox>
                            </VBox>

                            <VBox spacing="14" styleClass="settings-card">
                                <Label text="Theme" styleClass="settings-card-title"/>
                                <VBox spacing="10" fx:id="themeButtonsContainer">
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Button onAction="#handleThemeChange" userData="primer-dark" styleClass="theme-btn">
                                            <graphic>
                                                <VBox spacing="6" alignment="CENTER">
                                                    <HBox spacing="8" alignment="CENTER">
                                                        <Circle radius="8" fill="#172640"/>
                                                        <Circle radius="8" fill="#0f2a29"/>
                                                        <Circle radius="8" fill="#7aefa7"/>
                                                        <Circle radius="8" fill="#132246"/>
                                                        <Circle radius="8" fill="#8dc3fd"/>
                                                    </HBox>
                                                    <Label text="Dark" styleClass="theme-btn-label"/>
                                                </VBox>
                                            </graphic>
                                        </Button>
                                        <Button onAction="#handleThemeChange" userData="primer-light" styleClass="theme-btn">
                                            <graphic>
                                                <VBox spacing="6" alignment="CENTER">
                                                    <HBox spacing="8" alignment="CENTER">
                                                        <Circle radius="8" fill="#f8f9fa"/>
                                                        <Circle radius="8" fill="#dcfce7"/>
                                                        <Circle radius="8" fill="#166534"/>
                                                        <Circle radius="8" fill="#dbeafe"/>
                                                        <Circle radius="8" fill="#1e40af"/>
                                                    </HBox>
                                                    <Label text="Light" styleClass="theme-btn-label"/>
                                                </VBox>
                                            </graphic>
                                        </Button>
                                        <Button onAction="#handleThemeChange" userData="primer-electric-blue" styleClass="theme-btn">
                                            <graphic>
                                                <VBox spacing="6" alignment="CENTER">
                                                    <HBox spacing="8" alignment="CENTER">
                                                        <Circle radius="8" fill="#000d1f"/>
                                                        <Circle radius="8" fill="#002a3a"/>
                                                        <Circle radius="8" fill="#00e5ff"/>
                                                        <Circle radius="8" fill="#001a4a"/>
                                                        <Circle radius="8" fill="#60a0ff"/>
                                                    </HBox>
                                                    <Label text="Electric" styleClass="theme-btn-label"/>
                                                </VBox>
                                            </graphic>
                                        </Button>
                                    </HBox>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Button onAction="#handleThemeChange" userData="primer-cappuccino" styleClass="theme-btn">
                                            <graphic>
                                                <VBox spacing="6" alignment="CENTER">
                                                    <HBox spacing="8" alignment="CENTER">
                                                        <Circle radius="8" fill="#1e1e2e"/>
                                                        <Circle radius="8" fill="#1e3a2a"/>
                                                        <Circle radius="8" fill="#a6e3a1"/>
                                                        <Circle radius="8" fill="#1a2640"/>
                                                        <Circle radius="8" fill="#89dceb"/>
                                                    </HBox>
                                                    <Label text="Catppuccin" styleClass="theme-btn-label"/>
                                                </VBox>
                                            </graphic>
                                        </Button>
                                        <Button onAction="#handleThemeChange" userData="primer-sunset" styleClass="theme-btn">
                                            <graphic>
                                                <VBox spacing="6" alignment="CENTER">
                                                    <HBox spacing="8" alignment="CENTER">
                                                        <Circle radius="8" fill="#1a0e05"/>
                                                        <Circle radius="8" fill="#2e1205"/>
                                                        <Circle radius="8" fill="#ffb347"/>
                                                        <Circle radius="8" fill="#2e0a0a"/>
                                                        <Circle radius="8" fill="#ff6b6b"/>
                                                    </HBox>
                                                    <Label text="Sunset" styleClass="theme-btn-label"/>
                                                </VBox>
                                            </graphic>
                                        </Button>
                                        <Button onAction="#handleThemeChange" userData="primer-midnight" styleClass="theme-btn">
                                            <graphic>
                                                <VBox spacing="6" alignment="CENTER">
                                                    <HBox spacing="8" alignment="CENTER">
                                                        <Circle radius="8" fill="#12071e"/>
                                                        <Circle radius="8" fill="#1e0a2e"/>
                                                        <Circle radius="8" fill="#d080ff"/>
                                                        <Circle radius="8" fill="#0a1a2e"/>
                                                        <Circle radius="8" fill="#80b0ff"/>
                                                    </HBox>
                                                    <Label text="Midnight" styleClass="theme-btn-label"/>
                                                </VBox>
                                            </graphic>
                                        </Button>
                                    </HBox>
                                </VBox>
                            </VBox>

                            <VBox spacing="14" styleClass="settings-card">
                                <Label text="Notifications" styleClass="settings-card-title"/>
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Toast Notifications" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="settings-toggle-label"/>
                                    <ToggleSwitch fx:id="enableToastToggle" styleClass="toggle-switch"/>
                                </HBox>
                                <VBox spacing="4">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="Notification Duration"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="notifDurationLabel" text="4s" styleClass="val-label"/>
                                    </HBox>
                                    <Slider fx:id="notifDurationSlider" min="2" max="10" majorTickUnit="1" minorTickCount="0" snapToTicks="true" showTickMarks="true" showTickLabels="true"/>
                                </VBox>
                            </VBox>

                        </VBox>
                    </ScrollPane>
                </Tab>
                <Tab text="Sound">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="16" style="-fx-padding: 22 25 22 25;">

                            <VBox spacing="14" styleClass="settings-card">
                                <Label text="Master Volume" styleClass="settings-card-title"/>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="mdi2v-volume-high" styleClass="settings-volume-icon"/>
                                    <Slider fx:id="masterVolumeSlider" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="masterVolumeLabel" text="100%" styleClass="val-label" minWidth="45"/>
                                </HBox>
                            </VBox>

                            <VBox spacing="14" styleClass="settings-card">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Alarm" styleClass="settings-card-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button onAction="#handlePreviewAlarm" styleClass="settings-preview-btn">
                                        <graphic>
                                            <FontIcon iconLiteral="mdi2p-play-circle-outline" styleClass="settings-preview-icon"/>
                                        </graphic>
                                    </Button>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="mdi2b-bell-outline" styleClass="settings-volume-icon"/>
                                    <Slider fx:id="alarmVolumeSlider" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="alarmVolumeValLabel" text="100%" styleClass="val-label" minWidth="45"/>
                                </HBox>
                            </VBox>

                            <VBox spacing="14" styleClass="settings-card">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Notifications" styleClass="settings-card-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button onAction="#handlePreviewNotification" styleClass="settings-preview-btn">
                                        <graphic>
                                            <FontIcon iconLiteral="mdi2p-play-circle-outline" styleClass="settings-preview-icon"/>
                                        </graphic>
                                    </Button>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="mdi2n-notification-clear-all" styleClass="settings-volume-icon"/>
                                    <Slider fx:id="notificationVolumeSlider" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="notificationVolumeLabel" text="100%" styleClass="val-label" minWidth="45"/>
                                </HBox>
                            </VBox>

                            <VBox spacing="14" styleClass="settings-card">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Background Music" styleClass="settings-card-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button onAction="#handleToggleMusic" styleClass="settings-preview-btn">
                                        <graphic>
                                            <FontIcon fx:id="musicToggleIcon" iconLiteral="mdi2p-play-circle-outline" styleClass="settings-preview-icon"/>
                                        </graphic>
                                    </Button>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="mdi2m-music-circle-outline" styleClass="settings-volume-icon"/>
                                    <Slider fx:id="backgroundMusicVolumeSlider" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="backgroundMusicVolumeLabel" text="100%" styleClass="val-label" minWidth="45"/>
                                </HBox>
                            </VBox>

                        </VBox>
                    </ScrollPane>
                </Tab>
                <Tab text="About">
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="16" style="-fx-padding: 22 25 22 25;" alignment="TOP_CENTER">

                            <VBox spacing="14" styleClass="settings-card" alignment="CENTER">
                                <FontIcon iconLiteral="mdi2t-timer-outline" styleClass="settings-about-icon"/>
                                <Label text="Study Tracker" styleClass="settings-about-title"/>
                                <Label fx:id="appVersionLabel" text="v1.0.0" styleClass="settings-about-version"/>
                                <Label text="A Study tracker with session tracking, planning, and analytics."
                                       wrapText="true" textAlignment="CENTER" styleClass="settings-about-desc"/>
                            </VBox>

                            <VBox spacing="14" styleClass="settings-card-danger">
                                <Label text="Danger Zone" styleClass="settings-card-title-danger"/>
                                <Label text="Reset all settings to their default values. Your session data will not be affected."
                                       wrapText="true" styleClass="settings-danger-desc"/>
                                <Button onAction="#handleResetAllSettings" text="Reset All Settings" styleClass="settings-danger-btn" maxWidth="Infinity"/>
                            </VBox>

                        </VBox>
                    </ScrollPane>
                </Tab>
            </TabPane>
        </VBox>
    </GridPane>

    <GridPane fx:id="setupPane" visible="false" managed="false" maxHeight="Infinity" maxWidth="Infinity">
        <columnConstraints>
            <ColumnConstraints percentWidth="20" />
            <ColumnConstraints percentWidth="60" />
            <ColumnConstraints percentWidth="20" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints percentHeight="10" />
            <RowConstraints percentHeight="80" />
            <RowConstraints percentHeight="10" />
        </rowConstraints>
        <Region onMouseClicked="#toggleSetup" style="-fx-background-color: rgba(0,0,0,0.7);" GridPane.columnSpan="3" GridPane.rowSpan="3"><effect><GaussianBlur radius="15" /></effect></Region>
        <StackPane fx:id="setupBox" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <HBox spacing="20" styleClass="setup-main-box" >
                <VBox spacing="10" prefWidth="250" >
                    <Label text="Tags" alignment="CENTER" styleClass="setup-section-title" />
                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="setup-scroll">
                        <VBox fx:id="tagsListContainer" spacing="5" />
                    </ScrollPane>
                    <Separator styleClass="separator-setup" />
                    <TextField fx:id="tagNameInput" styleClass="search-input" promptText="New Tag Name" />
                    <ColorPicker fx:id="tagColorInput" styleClass="search-input" maxWidth="Infinity" />
                    <Button text="Add Tag" onAction="#handleAddNewTag" maxWidth="Infinity" styleClass="button-secondary" />
                </VBox>

                <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="separator-setup-vertical">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Search Tasks" styleClass="setup-section-title" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button maxWidth="-Infinity" maxHeight="-Infinity" text="✕" onAction="#toggleSetup" styleClass="close-button" />
                    </HBox>
                    <TextField fx:id="fuzzySearchInput" promptText="Type to search..." styleClass="search-input" />
                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="setup-scroll">
                        <VBox fx:id="fuzzyResultsContainer" spacing="8" />
                    </ScrollPane>

                    <VBox spacing="10" styleClass="selection-preview-box">
                        <Label fx:id="selectedNameLabel" text="Nothing selected" styleClass="selection-label" />
                    </VBox>
                </VBox>
            </HBox>
        </StackPane>
    </GridPane>

    <GridPane fx:id="summaryPane" visible="false" managed="false" maxHeight="Infinity" maxWidth="Infinity">
        <columnConstraints>
            <ColumnConstraints percentWidth="35" />
            <ColumnConstraints percentWidth="30" />
            <ColumnConstraints percentWidth="35" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints percentHeight="20" />
            <RowConstraints percentHeight="60" />
            <RowConstraints percentHeight="20" />
        </rowConstraints>
        <Region onMouseClicked="#toggleSummary" style="-fx-background-color: rgba(0,0,0,0.7);" GridPane.columnSpan="3" GridPane.rowSpan="3"><effect><GaussianBlur radius="15" /></effect></Region>
        <StackPane fx:id="summaryBox" styleClass="summaryStackPane" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <VBox  spacing="40" >
                <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
                <VBox alignment="CENTER">
                    <HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button maxWidth="-Infinity" maxHeight="-Infinity" text="✕" onAction="#toggleSummary" styleClass="close-button" />
                    </HBox>
                    <Label text="Session Finished" styleClass="summaryTitle" />
                </VBox>

                <VBox spacing="8">
                    <padding><Insets right="50" left="50"/></padding>
                    <Label text="Title" styleClass="section-label" />
                    <TextField fx:id="summaryTitle" styleClass="search-input" />
                </VBox>

                <VBox spacing="8">
                    <padding><Insets right="50" left="50"/></padding>
                    <Label text="Description" styleClass="section-label" />
                    <TextArea fx:id="summaryDesc" prefHeight="250" wrapText="true" />
                </VBox>

                <VBox spacing="10" alignment="CENTER">
                    <padding><Insets top="15"/></padding>
                    <HBox fx:id="starsContainer" spacing="10" alignment="CENTER" />
                </VBox>


                <HBox spacing="15" alignment="CENTER">
                    <Button text="Save Session" onAction="#handleSaveSummary" styleClass="button-main" />
                    <Button onAction="#handleDiscardSummary" style="-fx-background-color: transparent; -fx-cursor: hand">
                        <graphic>
                            <FontIcon styleClass="trashIcon"/>
                        </graphic>
                        <tooltip>
                            <Tooltip text="Delete Session" showDelay="250ms" />
                        </tooltip>
                    </Button>
                </HBox>
            </VBox>
        </StackPane>
    </GridPane>

    <StackPane fx:id="confirmOverlay" visible="false" managed="false" >
        <Region  onMouseClicked="#toggleConfirmDelete" style="-fx-background-color: rgba(0,0,0,0.7);" GridPane.columnSpan="3" GridPane.rowSpan="3"><effect><GaussianBlur radius="15" /></effect></Region>
        <VBox fx:id="confirmBox" spacing="25" alignment="CENTER" maxWidth="350" maxHeight="200"
              styleClass="confirm-dialog-card">
            <padding><Insets bottom="30" left="30" right="30" top="30" /></padding>

            <VBox spacing="10" alignment="CENTER">
                <Label text="Delete Session" styleClass="confirm-title" />
                <Label text="This action cannot be undone and the session will be permanently lost."
                       wrapText="true" textAlignment="CENTER" styleClass="confirm-message" />
            </VBox>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Cancel" onAction="#toggleConfirmDelete" styleClass="btn-cancel" />
                <Button text="Confirm" onAction="#onConfirmDeleteClick"  styleClass="btn-confirm-delete" />
            </HBox>
        </VBox>
    </StackPane>

    <StackPane fx:id="confirmTagOverlay" visible="false" managed="false" >
        <Region  onMouseClicked="#closeConfirmDeleteTag" style="-fx-background-color: rgba(0,0,0,0.7);" GridPane.columnSpan="3" GridPane.rowSpan="3"><effect><GaussianBlur radius="15" /></effect></Region>
        <VBox fx:id="confirmTagBox" spacing="25" alignment="CENTER" maxWidth="350" maxHeight="200"
              styleClass="confirm-dialog-card">
            <padding><Insets bottom="30" left="30" right="30" top="30" /></padding>

            <VBox spacing="10" alignment="CENTER">
                <Label text="Delete Tag" styleClass="confirm-title" />
                <Label text="This action cannot be undone and the tag will be permanently lost and all his sessions, tasks and scheduled sessions."
                       wrapText="true" textAlignment="CENTER" styleClass="confirm-message" />
            </VBox>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Cancel" onAction="#closeConfirmDeleteTag" styleClass="btn-cancel" />
                <Button text="Confirm" onAction="#onConfirmDeleteTagClick"  styleClass="btn-confirm-delete" />
            </HBox>
        </VBox>
    </StackPane>

    <GridPane fx:id="editSessionPane" visible="false" managed="false" maxHeight="Infinity" maxWidth="Infinity">
        <columnConstraints>
            <ColumnConstraints percentWidth="35" />
            <ColumnConstraints percentWidth="30" />
            <ColumnConstraints percentWidth="35" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints percentHeight="10" />
            <RowConstraints percentHeight="80" />
            <RowConstraints percentHeight="10" />
        </rowConstraints>

        <Region onMouseClicked="#toggleEditSession" style="-fx-background-color: rgba(0,0,0,0.7);" GridPane.columnSpan="3" GridPane.rowSpan="3">
            <effect><GaussianBlur radius="15" /></effect>
        </Region>

        <StackPane fx:id="editSessionBox" styleClass="summaryStackPane" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <VBox spacing="25">
                <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

                <VBox alignment="CENTER">
                    <HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="✕" onAction="#toggleEditSession" styleClass="close-button" />
                    </HBox>
                    <Label text="Edit Session" styleClass="summaryTitle" />
                </VBox>

                <VBox spacing="15">
                    <HBox spacing="10">
                        <VBox HBox.hgrow="ALWAYS" spacing="5">
                            <Label text="Tag" styleClass="section-label" />
                            <ComboBox fx:id="editTagCombo" maxWidth="Infinity" styleClass="search-input" />
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="5">
                            <Label text="Task" styleClass="section-label" />
                            <ComboBox fx:id="editTaskCombo" maxWidth="Infinity" styleClass="search-input" />
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="8">
                    <Label text="Title" styleClass="section-label" />
                    <TextField fx:id="editTitleField" styleClass="search-input" />
                </VBox>

                <VBox spacing="8">
                    <Label text="Description" styleClass="section-label" />
                    <TextArea fx:id="editDescArea" prefHeight="200" wrapText="true" />
                </VBox>

                <VBox spacing="10" alignment="CENTER">
                    <HBox fx:id="editStarsContainer" spacing="10" alignment="CENTER"  />
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <HBox spacing="20" alignment="CENTER">
                    <Button text="Update Session" onAction="#handleEditSession" styleClass="button-main" />
                    <Button text="Cancel" onAction="#toggleEditSession" style="-fx-background-color: transparent; -fx-text-fill: -text-muted; -fx-cursor: hand;" />
                </HBox>
            </VBox>
        </StackPane>
    </GridPane>

    <StackPane fx:id="plannerOverlayLayer"
               visible="false"
               managed="false"
               pickOnBounds="true"
               StackPane.alignment="CENTER" />

    <VBox fx:id="notificationContainer"
          mouseTransparent="true"
          visible="false"
          managed="false"
          alignment="TOP_RIGHT"
          spacing="10"
          maxWidth="350"
          maxHeight="-Infinity"
          StackPane.alignment="TOP_RIGHT">
        <padding>
            <Insets top="20" right="20" />
        </padding>
    </VBox>

</StackPane>
